# --- FUNCIÓN PARA CREAR PROYECTOS GO + FIBER + DOCKER ---
new_repo() {
    local nombre=$1
    if [ -z "$nombre" ]; then
        echo -e "\e[33m⚠️ Indica un nombre para el proyecto. Ej: new_repo mi-contabilidad\e[0m"
        return
    fi

    # 1. Estructura de Carpetas
    echo -e "\e[34m📂 Creando estructura para: $nombre...\e[0m"
    mkdir -p "$nombre"/{ctrl,db,help,middleware,static,models,rutas,config,views,tests}
    cd "$nombre"

    # 2. Inicializar Go
    go mod init "$nombre"
    echo -e "\e[36m📦 Descargando dependencias (Fiber, GORM, Postgres)...\e[0m"
    go get github.com/gofiber/fiber/v2
    go get github.com/gofiber/template/handlebars/v3
    go get gorm.io/gorm
    go get gorm.io/driver/postgres

    # 3. Archivos de Configuración (.gitignore, .env, Docker)
    echo "tmp/" > .gitignore
    echo "main" >> .gitignore
    echo ".env" >> .gitignore
    echo "postgres_data/" >> .gitignore

    cat <<EOF > .env
DB_HOST=db
DB_PORT=5432
DB_USER=admin
DB_PASS=admin123
DB_NAME=${nombre}_db
EOF

    # Dockerfile
    cat <<EOF > Dockerfile
FROM golang:alpine
WORKDIR /app
RUN apk add --no-cache gcc musl-dev
RUN go install github.com/air-verse/air@latest
COPY go.mod go.sum ./
RUN go mod download
COPY . .
CMD ["air", "-c", ".air.toml"]
EOF

    # Docker-compose (con el healthcheck que usas)
    cat <<EOF > docker-compose.yml
services:
  app:
    build: .
    container_name: ${nombre}_app
    ports: ["3000:3000"]
    volumes:
      - .:/app
    env_file: [.env]
    depends_on:
      db:
        condition: service_healthy
  db:
    image: postgres:15-alpine
    container_name: ${nombre}_db
    environment:
      POSTGRES_USER: admin
      POSTGRES_PASSWORD: admin123
      POSTGRES_DB: ${nombre}_db
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U admin -d ${nombre}_db"]
      interval: 5s
      timeout: 5s
      retries: 5
volumes:
  postgres_data:
EOF

    # 4. Código Boilerplate (Main y DB)
    cat <<EOF > main.go
package main
import (
    "$nombre/db"
    "$nombre/rutas"
    "github.com/gofiber/fiber/v2"
    "github.com/gofiber/template/handlebars/v3"
)
func main() {
    db.Connect()
    engine := handlebars.New("./views", ".hbs")
    app := fiber.New(fiber.Config{Views: engine})
    app.Static("/static", "./static")
    rutas.Setup(app)
    app.Listen(":3000")
}
EOF

    mkdir -p db
    cat <<EOF > db/db.go
package db
import (
    "fmt"
    "os"
    "gorm.io/driver/postgres"
    "gorm.io/gorm"
)
var DB *gorm.DB
func Connect() {
    dsn := fmt.Sprintf("host=%s user=%s password=%s dbname=%s port=%s sslmode=disable", 
        os.Getenv("DB_HOST"), os.Getenv("DB_USER"), os.Getenv("DB_PASS"), os.Getenv("DB_NAME"), os.Getenv("DB_PORT"))
    database, err := gorm.Open(postgres.Open(dsn), &gorm.Config{})
    if err != nil { panic("Fallo conexión DB") }
    DB = database
}
EOF

    # 5. Git Inicial
    git init && git add . && git commit -m "feat: initial commit from automation script"
    
    echo -e "\n\e[35m🚀 PROYECTO '$nombre' CREADO Y LISTO EN WSL\e[0m"
}

# Alias para llamar a la función con una sola letra como en tu Windows
alias n='new_repo'

show_dashboard

# --- UTILIDADES DE LIMPIEZA (Invoke-CleanNvim) ---
invoke_clean_nvim() {
    clear
    # En Linux simplemente llamamos a nvim
    nvim "$@"
    clear
    echo -e "\n\e[32m  󰄬 Edición finalizada.\e[0m"
    echo -ne "\e[36m  󱊄 Presiona ENTER para volver al menú...\e[0m"
    read
}

# --- FUNCIONES DE GIT ---

get_git_stash() {
    # Comprobar si es repo git
    git rev-parse --git-dir > /dev/null 2>&1 || return
    
    local stash=$(git stash list | fzf --reverse --prompt="Git stash > " \
        --preview 'git stash show --color=always -p {1}')
    
    [ -z "$stash" ] && return
    echo "$stash" | cut -d':' -f1
}

restore_git_stash() {
    local ref=$(get_git_stash)
    [ -n "$ref" ] && git stash pop "$ref"
}

remove_git_stash() {
    local ref=$(get_git_stash)
    [ -z "$ref" ] && return
    
    clear
    echo -ne "\e[33m⚠️ ¿Eliminar $ref ? (y/N): \e[0m"
    read confirm
    if [ "$confirm" == "y" ]; then
        git stash drop "$ref"
    fi
}

get_git_log() {
    git rev-parse --is-inside-work-tree > /dev/null 2>&1 || return
    local log_format="%C(yellow)%h%C(reset) %C(green)%ad%C(reset) %s"
    
    while true; do
        local selection=$(git log --graph --color=always --format="$log_format" --date=short | \
            fzf --ansi --no-sort --reverse --height="100%" \
                --preview "git show --color=always {2}" \
                --header "ENTER: Detalle | ESC: Volver")
        
        [ -z "$selection" ] && break
        
        local hash=$(echo "$selection" | grep -oE '[a-f0-9]{7,40}' | head -n 1)
        
        if [ -n "$hash" ]; then
            clear
            git show --color=always "$hash" | less -R
            clear
        fi
    done
}

switch_git_branch() {
    local branch=$(git branch --color=always | fzf --ansi --reverse --prompt="Checkout a rama > ")
    if [ -n "$branch" ]; then
        # Limpia el '*' de la rama actual y hace checkout
        git checkout $(echo "$branch" | sed 's/^[* ]*//')
    fi
}

# Función para Git: Add, Commit y Push (opcional)
gac() {
    if [ -z "$1" ]; then
        echo "❌ Error: Te falta el mensaje del commit."
        echo "Uso: gac \"mi mensaje de cambio\""
        return 1
    fi

    git add .
    git commit -m "$1"
    
    echo "✅ Cambios guardados localmente."
    
    # Preguntar si quieres hacer push de una vez
    read -p "¿Quieres hacer push ahora? (s/n): " respuesta
    if [[ "$respuesta" =~ ^[Ss]$ ]]; then
        git push
        echo "🚀 ¡Todo arriba en la nube!"
    else
        echo "👍 Ok, commit guardado pero sin push."
    fi
}

# --- NAVEGACIÓN DE PROYECTOS (Project Jumper) ---

p_jump() {
    local current=$(pwd)
    # Ruta de tus proyectos en WSL
    local base_path="/mnt/c/Users/Usuario/Documents/Desarrollo"
    
    while true; do
        # Listar directorios excluyendo carpetas pesadas
        local selected=$(find . -maxdepth 1 -type d ! -path '*/.*' ! -name "vendor" ! -name "node_modules" -printf "%f\n" | \
            fzf --reverse --height 40% --prompt="󱊲 Saltar a > " --header "ENTER: Entrar | ESC: Salir")
        
        [ -z "$selected" ] && break
        
        cd "$selected"
        
        # Si detecta entorno de desarrollo, se queda ahí
        if [ -f "go.mod" ] || [ -f "main.go" ] || [ -d ".git" ]; then
            clear
            echo -e "\e[36m🚀 Contexto actualizado: $(pwd)\e[0m"
            ls
            break
        fi
    done
}

# --- GIT BLAME CON NVIM ---

get_git_blame() {
    local file=$(git ls-files | fzf --prompt="Blame archivo > " --reverse)
    [ -z "$file" ] && return

    local selected=$(git blame --color=always "$file" | \
        fzf --ansi --no-sort --reverse --prompt="Blame línea > " \
            --preview "git show --color=always {1}")

    if [ -n "$selected" ]; then
        # Extraer número de línea (en bash el split es distinto)
        local line=$(echo "$selected" | awk '{print $3}' | tr -d ')')
        invoke_clean_nvim "+$line" "$file"
    fi
}

# Función Genérica para buscar símbolos usando Regex
# $1: Regex de búsqueda, $2: Prompt, $3: Extensiones (ej: "*.go")
_get_symbols() {
    local regex=$1
    local prompt=$2
    local ext=$3

    # Buscamos archivos, filtramos por regex y formateamos: ruta:linea:contenido
    local results=$(find . -maxdepth 4 -name "$ext" -not -path "*/vendor/*" -not -path "*/node_modules/*" \
        | xargs grep -nE "$regex" 2>/dev/null)

    if [ -z "$results" ]; then
        echo -e "\e[33mNo se encontraron símbolos.\e[0m"
        return
    fi

    local selected=$(echo "$results" | fzf --ansi --reverse --height 40% \
        --prompt="$prompt > " \
        --delimiter ":" --nth 3.. \
        --preview 'bat --style=numbers --color=always --highlight-line {2} {1}')

    if [ -n "$selected" ]; then
        local file=$(echo "$selected" | cut -d':' -f1)
        local line=$(echo "$selected" | cut -d':' -f2)
        invoke_clean_nvim "+$line" "$file"
    fi
}

# Alias específicos usando la función maestra
gosym() { _get_symbols "^func|^type" "Go symbol" "*.go"; }
pysym() { _get_symbols "^def|^class" "Python symbol" "*.py"; }
jssym() { _get_symbols "^function|^class|^const|^let|^var" "JS symbol" "*.js"; }
cssym() { _get_symbols "^[.#\$@]\w+" "CSS symbol" "*.css"; }
hbssym() { _get_symbols "{{[#/>]?\s*\w+" "HBS symbol" "*.hbs"; }

# --- BUSCADOR POR CTAGS (Universal) ---
get_fzf_symbol() {
    # Evitar ejecutar en carpetas raíz
    if [ ${#PWD} -le 5 ]; then
        echo -e "\e[31m🛑 ERROR: Carpeta muy sensible.\e[0m"
        return
    fi

    # Generar tags si no existen o se pide update (-u)
    if [ "$1" == "-u" ] || [ ! -f "tags" ]; then
        echo -e "\e[36m⏳ Generando tags...\e[0m"
        ctags -R --exclude="node_modules" --exclude="vendor" --exclude=".git" .
    fi

    [ ! -f "tags" ] && return

    # Filtrar y buscar con FZF
    local selected=$(grep -v '^!' tags | fzf --reverse --nth=1,4 \
        --prompt="Símbolo (Tags) > " \
        --preview 'bat --style=numbers --color=always --highlight-line {3} {2}')

    if [ -n "$selected" ]; then
        # Ctags format: nombre [tab] archivo [tab] /regex/ ;" [tab] line:N
        local file=$(echo "$selected" | cut -f2)
        local line=$(echo "$selected" | grep -oE 'line:[0-9]+' | cut -d':' -f2)
        [ -z "$line" ] && line=1
        invoke_clean_nvim "+$line" "$file"
    fi
}
alias ssym='get_fzf_symbol'

