# Función para mostrar el header
show_dashboard() {
    clear
    # Color aleatorio (usando códigos ANSI)
    colores=(31 32 33 34 35 36)
    color=${colores[$RANDOM % ${#colores[@]}]}
    echo -e "\e[${color}m$logoJuanca\e[0m"

    echo -e "\e[35m  Git Ready \e[0m| \e[36m Go \e[0m| \e[33m JS \e[0m| \e[31m HTML \e[0m"
    echo "---------------------------------------------------------"
}

