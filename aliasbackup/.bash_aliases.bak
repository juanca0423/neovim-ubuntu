alias d-ps='docker-compose ps -a'

# Entrar al contenedor de la App (basado en el nombre de la carpeta)
enter_app() {
    local proyecto=$(basename "$PWD")
    local container="${proyecto}_app"
    if [ $(docker ps -q -f name=$container) ]; then
        docker exec -it "$container" sh
    else
        echo -e "\e[31m❌ Contenedor $container no encontrado.\e[0m"
    fi
}

# Entrar a la DB de Postgres
enter_db() {
    local proyecto=$(basename "$PWD")
    local container="${proyecto}_db"
    if [ $(docker ps -q -f name=$container) ]; then
        echo -e "\e[36m🐘 Conectando a Postgres: $container...\e[0m"
        docker exec -it "$container" psql -U admin -d "${proyecto}_db"
    else
        echo -e "\e[31m❌ DB no encontrada.\e[0m"
    fi
}
alias edb='enter_db'
alias eapp='enter_app'
get_grep() {
    local pattern=$1
    if [ -z "$pattern" ]; then
        echo -n "🔍 Texto a buscar: "
        read pattern
    fi
    [ -z "$pattern" ] && return

    # Usamos ripgrep (rg) que es instantáneo
    local results=$(rg --line-number --column --no-heading --color=always --smart-case "$pattern" 2>/dev/null)

    if [ -z "$results" ]; then
        echo -e "\e[33mNo se encontraron coincidencias.\e[0m"
        return
    fi

    local selected=$(echo "$results" | fzf --ansi --reverse --delimiter ":" \
        --nth 4.. \
        --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
        --header "ENTER: Editar | ESC: Volver")

    if [ -n "$selected" ]; then
        local file=$(echo "$selected" | cut -d':' -f1)
        local line=$(echo "$selected" | cut -d':' -f2)
        invoke_clean_nvim "+$line" "$file"
    fi
}
alias sgr='get_grep'

# Configura tu ruta de proyectos (Ajusta 'Usuario')
export RUTA_PROYECTOS="/mnt/c/Users/Usuario/Documents/Desarrollo"

# Función de Preview (Lo que se ve a la derecha en fzf)
_project_preview() {
    local folder="$RUTA_PROYECTOS/$1"
    echo -e "\e[36m── PROYECTO: ${1^^} ──\e[0m"
    if [ -d "$folder" ]; then
        ls -F --color=always "$folder" | head -n 10
        if [ -f "$folder/go.mod" ]; then echo -e "\n\e[32m󰟓 Go Project detected\e[0m"; fi
        if [ -f "$folder/docker-compose.yml" ]; then echo -e "\e[34m🐳 Docker Ready\e[0m"; fi
    fi
}
export -f _project_preview

# El selector principal
proyecto() {
    local selected=$(ls "$RUTA_PROYECTOS" | fzf --reverse \
        --header " 📂 SELECCIONA PROYECTO " \
        --preview "_project_preview {}" --preview-window "right:60%")

    if [ -n "$selected" ]; then
        cd "$RUTA_PROYECTOS/$selected"
        clear
        show_dashboard  # Llama a tu logo
        echo -e "\e[32mContexto: $selected\e[0m\n"
        ls
    fi
}

docker_menu() {
    if [ ! -f "docker-compose.yml" ]; then
        echo -e "\e[31m❌ No hay docker-compose.yml aquí.\e[0m"
        return
    fi

    options="🐳 Status (ps)\n🚀 Levantar (up)\n🛑 Detener (down)\n💻 Shell (entrar)\n📦 Logs\n« Volver"
    
    selected=$(echo -e "$options" | fzf --reverse --header " 🐳 DOCKER MENU " --height 15%)

    case "$selected" in
        *"Status"*) docker-compose ps -a; read -p "Presiona ENTER..." ;;
        *"Levantar"*) docker-compose up --build -d ;;
        *"Detener"*) docker-compose down ;;
        *"Shell"*)
            local container=$(docker ps --format "{{.Names}}" | fzf --reverse --header " Selecciona Contenedor ")
            [ -n "$container" ] && docker exec -it "$container" sh
            ;;
        *"Logs"*) docker-compose logs -f ;;
    esac
}
alias dmenu='docker_menu'

git_menu() {
    git rev-parse --is-inside-work-tree > /dev/null 2>&1 || { echo "No es un repo Git"; return; }

    # Definimos las categorías
    cat_options="🔍 Buscadores y Logs\n📦 Flujo (Commit/Stash)\n🛠️ Avanzado\n🌿 Status Rápido\n🚀 Pull / Push\n« Salir"
    
    cat_sel=$(echo -e "$cat_options" | fzf --reverse --header "  HERRAMIENTAS DE GIT " --height 20%)

    case "$cat_sel" in
        *"Buscadores"*)
            sub="⚡ Buscar texto (grep)\n📜 Log (fzf)\n📝 Blame\n🏷️ Símbolos\n« Volver"
            sub_sel=$(echo -e "$sub" | fzf --reverse --header " GIT > BUSCAR ")
            case "$sub_sel" in
                *"texto"*) get_grep ;;
                *"Log"*) get_git_log ;;
                *"Blame"*) get_git_blame ;;
                *"Símbolos"*) gosym ;;
            esac
            ;;
        *"Flujo"*)
            sub="🔍 Status Detallado\n💾 Commit Todo\n Cambiar Rama\n📦 Stash: Pop\n« Volver"
            sub_sel=$(echo -e "$sub" | fzf --reverse --header " GIT > FLUJO ")
            case "$sub_sel" in
                *"Status"*) git status; read -p "Enter..." ;;
                *"Commit"*) read -p "Mensaje: " msg; git add .; git commit -m "$msg" ;;
                *"Rama"*) switch_git_branch ;;
                *"Stash"*) restore_git_stash ;;
            esac
            ;;
            # (Dentro de tu función git_menu, en la sección de Avanzado)
        *"Avanzado"*)
            adv_options="🔨 Rebase Interactivo\n🍒 Cherry-pick\n🔍 Bisect: Iniciar\n🧹 Bisect: Reset\n📋 Blame (Autoría)\n« Volver"
            adv_sel=$(echo -e "$adv_options" | fzf --reverse --header " GIT > AVANZADO " --height 15%)
            
            case "$adv_sel" in
                *"Rebase"*) update_git_rebase ;;
                *"Cherry"*) copy_git_cherry_pick ;;
                *"Bisect: Iniciar"*) start_git_bisect ;;
                *"Bisect: Reset"*) git bisect reset && echo "Bisect finalizado." ;;
                *"Blame"*) get_git_blame ;;
            esac
            ;;
        *"Status Rápido"*) git status -s; read -p "Enter..." ;;
        *"Pull"*) git pull && git push ;;
    esac
}
alias gmenu='git_menu'

# --- REBASE INTERACTIVO ---
update_git_rebase() {
    git rev-parse --git-dir > /dev/null 2>&1 || return
    
    local commit=$(git log --oneline --decorate --color=always | \
        fzf --ansi --reverse --prompt="Rebase desde (commit base) > " \
            --preview 'git show --color=always {1}')

    if [ -n "$commit" ]; then
        local hash=$(echo "$commit" | awk '{print $1}')
        # En Bash, simplemente ejecutamos git rebase -i. 
        # Nvim se abrirá automáticamente si lo tienes como editor por defecto.
        git rebase -i "${hash}^"
    fi
}

# --- CHERRY-PICK ---
copy_git_cherry_pick() {
    git rev-parse --git-dir > /dev/null 2>&1 || return

    local commit=$(git log --oneline --decorate --color=always | \
        fzf --ansi --reverse --prompt="Cherry-pick (aplicar commit) > " \
            --preview 'git show --color=always {1}')

    if [ -n "$commit" ]; then
        local hash=$(echo "$commit" | grep -oE '[a-f0-9]{7,40}' | head -n 1)
        echo -e "\n\e[33m󰄬 Aplicando cherry-pick de $hash...\e[0m"
        git cherry-pick "$hash"
        sleep 1
    fi
}

# --- BISECT (Depuración de Bugs) ---
start_git_bisect() {
    git rev-parse --git-dir > /dev/null 2>&1 || return

    echo -e "\e[35m--- CONFIGURACIÓN DE BISECT ---\e[0m"
    
    # Seleccionar commit MALO
    local bad=$(git log --oneline --color=always | fzf --ansi --reverse --prompt="1. Seleccione commit MALO (con bug) > ")
    [ -z "$bad" ] && return
    local bad_hash=$(echo "$bad" | awk '{print $1}')

    # Seleccionar commit BUENO
    local good=$(git log --oneline --color=always | fzf --ansi --reverse --prompt="2. Seleccione commit BUENO (limpio) > ")
    [ -z "$good" ] && return
    local good_hash=$(echo "$good" | awk '{print $1}')

    git bisect start
    git bisect bad "$bad_hash"
    git bisect good "$good_hash"
    
    echo -e "\n\e[32m✅ Bisect iniciado en: $bad_hash...$good_hash\e[0m"
    echo "Usa 'git bisect good' o 'git bisect bad' según tus pruebas."
}

